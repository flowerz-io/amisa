{
  "name": "amisa-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node ./scripts/playwright-postinstall.mjs",
    "build": "tsc -p tsconfig.json",
    "build:railway": "npm run build && npx playwright install --with-deps chromium",
    "prepare:chromium": "npx playwright install --with-deps chromium",
    "railway-release": "npx playwright install --with-deps chromium && npm run build",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "openai": "^4.77.3",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
